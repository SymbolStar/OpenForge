#!/usr/bin/env bash
# openforge-worktree — manage per-agent git worktrees for multi-agent dev.
#
# Usage:
#   openforge-worktree add <agent> <task-slug> [--repo <path>]
#   openforge-worktree rm  <agent>/<task-slug>  [--repo <path>]
#   openforge-worktree ls  [--repo <path>]
#
# Conventions:
#   branch        = <agent>/<task-slug>
#   worktree path = <repo>.worktrees/<agent>-<task-slug>/
#
# Default repo is current git toplevel (or OPENFORGE_REPO env).

set -euo pipefail

c_ok()   { printf '\033[32m%s\033[0m\n' "$*"; }
c_warn() { printf '\033[33m%s\033[0m\n' "$*" >&2; }
c_err()  { printf '\033[31m%s\033[0m\n' "$*" >&2; }
die()    { c_err "openforge-worktree: $*"; exit 1; }

# ─── arg parsing ──────────────────────────────────────────────────────
cmd="${1:-}"
case "$cmd" in
  ""|-h|--help|help) sed -n '3,12p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
esac
shift || true

REPO=""
POSITIONAL=()
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) REPO="$2"; shift 2 ;;
    --repo=*) REPO="${1#*=}"; shift ;;
    -h|--help) sed -n '3,12p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done
set -- "${POSITIONAL[@]:-}"

# ─── resolve repo ─────────────────────────────────────────────────────
if [ -z "$REPO" ]; then
  REPO="${OPENFORGE_REPO:-}"
fi
if [ -z "$REPO" ]; then
  REPO="$(git rev-parse --show-toplevel 2>/dev/null || true)"
fi
[ -z "$REPO" ] && die "no repo (use --repo or run inside a git repo)"
[ -d "$REPO/.git" ] || die "not a git repo: $REPO"

REPO="$(cd "$REPO" && pwd)"
REPO_NAME="$(basename "$REPO")"
WT_ROOT="$(dirname "$REPO")/${REPO_NAME}.worktrees"

# ─── helpers ──────────────────────────────────────────────────────────
slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

branch_for() { printf '%s/%s' "$1" "$2"; }
path_for()   { printf '%s/%s-%s' "$WT_ROOT" "$1" "$2"; }

# ─── commands ─────────────────────────────────────────────────────────
do_add() {
  local agent="${1:?agent required}"
  local task_raw="${2:?task-slug required}"
  local task; task="$(slugify "$task_raw")"
  [ -z "$task" ] && die "task-slug is empty after slugify"

  local branch; branch="$(branch_for "$agent" "$task")"
  local wt;     wt="$(path_for     "$agent" "$task")"

  mkdir -p "$WT_ROOT"

  if [ -d "$wt" ]; then
    c_warn "worktree already exists, reusing: $wt"
    echo "$wt"
    return 0
  fi

  cd "$REPO"
  # Ensure main is fresh-ish so new branch starts from current origin/main.
  git fetch --quiet origin || true

  local base="origin/main"
  git rev-parse --verify --quiet "$base" >/dev/null || base="main"

  if git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null; then
    git worktree add "$wt" "$branch" >&2
  else
    git worktree add -b "$branch" "$wt" "$base" >&2
  fi

  c_ok "[openforge-worktree] created branch=$branch" >&2
  c_ok "[openforge-worktree] cwd=$wt" >&2
  echo "$wt"
}

do_rm() {
  local ref="${1:?branch (<agent>/<task-slug>) required}"
  case "$ref" in
    */*) : ;;
    *) die "expected <agent>/<task-slug>, got: $ref" ;;
  esac
  local agent="${ref%%/*}"
  local task="${ref#*/}"
  local branch="$ref"
  local wt; wt="$(path_for "$agent" "$task")"

  cd "$REPO"
  if [ -d "$wt" ]; then
    git worktree remove --force "$wt" >&2 || rm -rf "$wt"
    c_ok "[openforge-worktree] removed worktree $wt" >&2
  else
    c_warn "no worktree dir at $wt (already gone?)"
  fi

  if git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null; then
    if git branch -d "$branch" 2>/dev/null; then
      c_ok "[openforge-worktree] deleted local branch $branch" >&2
    else
      c_warn "local branch $branch not fully merged; keep with: git branch -D $branch"
    fi
  fi
}

do_ls() {
  cd "$REPO"
  git worktree list
}

case "$cmd" in
  add) do_add "$@" ;;
  rm|remove) do_rm "$@" ;;
  ls|list) do_ls "$@" ;;
  *) die "unknown command: $cmd (use add|rm|ls)" ;;
esac
